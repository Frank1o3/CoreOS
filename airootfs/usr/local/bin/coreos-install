#!/usr/bin/env bash
# =============================================================================
# CoreOS Installer (Updated)
# Arch-based minimal OS with i3 + Secure Boot + TPM2
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[0;33m'
BLU='\033[0;34m'
BLD='\033[1m'
RST='\033[0m'

info()    { echo -e "${BLU}${BLD}==> ${RST}${BLD}$*${RST}"; }
success() { echo -e "${GRN}${BLD}==> ${RST}${BLD}$*${RST}"; }
warn()    { echo -e "${YLW}${BLD}WARNING:${RST} $*"; }
die()     { echo -e "${RED}${BLD}ERROR:${RST} $*" >&2; exit 1; }

confirm() {
    local prompt="${1} [y/N] "
    local reply
    read -rp "$(echo -e ${YLW}${prompt}${RST})" reply
    [[ "${reply,,}" == "y" ]]
}

ask() {
    local prompt="$1"
    local var="$2"
    local default="${3:-}"
    local reply
    if [[ -n "$default" ]]; then
        read -rp "$(echo -e ${BLU}${prompt} [${default}]:${RST} )" reply
        printf -v "$var" '%s' "${reply:-$default}"
    else
        read -rp "$(echo -e ${BLU}${prompt}:${RST} )" reply
        printf -v "$var" '%s' "$reply"
    fi
}

ask_password() {
    local prompt="$1"
    local var="$2"
    local pass confirm
    while true; do
        read -srp "$(echo -e ${BLU}${prompt}:${RST} )" pass; echo
        read -srp "$(echo -e ${BLU}Confirm password:${RST} )" confirm; echo
        [[ "$pass" == "$confirm" ]] && break
        warn "Passwords do not match."
    done
    printf -v "$var" '%s' "$pass"
}

clear
echo -e "${BLD}"
cat << 'BANNER'
   ____                ___  ____
  / ___|___  _ __ ___|  _ \/ ___|
 | |   / _ \| '__/ _ \ | | \___ \
 | |__| (_) | | |  __/ |_| |___) |
  \____\___/|_|  \___|____/|____/

  Minimal Arch-based installer
BANNER
echo -e "${RST}"

[[ $EUID -eq 0 ]] || die "Run as root."
ping -c1 archlinux.org &>/dev/null || die "No internet."
[[ -d /sys/firmware/efi ]] || die "Not booted in UEFI mode."

info "Available disks:"
lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -v loop
echo

ask "Target disk (example: sda or nvme0n1)" DISK
DISK="/dev/$DISK"
[[ -b "$DISK" ]] || die "Disk not found."

warn "This will erase ALL data on $DISK"
confirm "Continue?" || exit 0

ask "Swap size in GB (0 to disable)" SWAP_GB "4"
ask "Hostname" HOSTNAME "coreos"
ask "Timezone" TIMEZONE "America/Santo_Domingo"
ask "Locale" LOCALE "en_US.UTF-8"

LUKS=false
if confirm "Enable LUKS encryption?"; then
    LUKS=true
    ask_password "LUKS passphrase" LUKS_PASS
fi

CREATE_USER=false
if confirm "Create a user?"; then
    CREATE_USER=true
    ask "Username" USERNAME
    ask_password "User password" USER_PASS
    GRANT_SUDO=false
    confirm "Grant sudo?" && GRANT_SUDO=true
fi

ask_password "Root password" ROOT_PASS

info "Ranking mirrors..."
if command -v reflector &>/dev/null; then
    reflector --country "Dominican Republic,United States" \
        --protocol https --age 12 --sort rate \
        --save /etc/pacman.d/mirrorlist || true
fi

info "Partitioning disk..."

wipefs -af "$DISK"
sgdisk --zap-all "$DISK"

sgdisk -n1:0:+512M -t1:ef00 -c1:"EFI" "$DISK"

if [[ "$SWAP_GB" -gt 0 ]]; then
    sgdisk -n2:0:+${SWAP_GB}G -t2:8200 -c2:"swap" "$DISK"
    sgdisk -n3:0:0 -t3:8300 -c3:"root" "$DISK"
fi

partprobe "$DISK"
sleep 2

case "$DISK" in
    *nvme*|*mmcblk*)
        EFI="${DISK}p1"
        [[ "$SWAP_GB" -gt 0 ]] && SWAP="${DISK}p2" ROOT="${DISK}p3" || ROOT="${DISK}p2"
        ;;
    *)
        EFI="${DISK}1"
        [[ "$SWAP_GB" -gt 0 ]] && SWAP="${DISK}2" ROOT="${DISK}3" || ROOT="${DISK}2"
        ;;
esac

info "Formatting..."

mkfs.fat -F32 "$EFI"

if [[ "$SWAP_GB" -gt 0 ]]; then
    mkswap "$SWAP"
    swapon "$SWAP"
fi

if $LUKS; then
    printf "%s" "$LUKS_PASS" | cryptsetup luksFormat "$ROOT" --type luks2 --key-file -
    printf "%s" "$LUKS_PASS" | cryptsetup open "$ROOT" cryptroot --key-file -
    ROOT_REAL="/dev/mapper/cryptroot"
else
    ROOT_REAL="$ROOT"
fi

mkfs.ext4 "$ROOT_REAL"

info "Mounting..."

mount "$ROOT_REAL" /mnt
mkdir -p /mnt/boot
mount "$EFI" /mnt/boot

info "Installing base system..."

pacstrap -K /mnt --needed \
    base base-devel linux linux-firmware intel-ucode \
    systemd-ukify sbctl sbsigntools tpm2-tools efibootmgr \
    networkmanager iwd \
    pipewire pipewire-pulse wireplumber \
    xorg-server xorg-xinit xorg-xrandr \
    i3-wm i3status i3lock dmenu alacritty \
    git curl wget rsync vim nano less \
    sudo zsh grml-zsh-config \
    man-db man-pages \
    noto-fonts ttf-dejavu \
    brightnessctl unzip zip p7zip \
    htop fastfetch reflector

genfstab -U /mnt >> /mnt/etc/fstab

arch-chroot /mnt /bin/bash <<EOF

ln -sf /usr/share/zoneinfo/$TIMEZONE /etc/localtime
hwclock --systohc

sed -i "s/^#$LOCALE/$LOCALE/" /etc/locale.gen
locale-gen
echo LANG=$LOCALE > /etc/locale.conf

echo $HOSTNAME > /etc/hostname

echo "root:$ROOT_PASS" | chpasswd

if $CREATE_USER; then
    useradd -m -G wheel,audio,video,input -s /bin/zsh $USERNAME
    echo "$USERNAME:$USER_PASS" | chpasswd
    $GRANT_SUDO && sed -i 's/^# %wheel/%wheel/' /etc/sudoers
fi

systemctl enable NetworkManager
systemctl enable NetworkManager-wait-online

bootctl install

cat >/boot/loader/loader.conf <<BOOT
default coreos
timeout 5
BOOT

ROOT_UUID=\$(blkid -s UUID -o value $ROOT_REAL)

cat >/boot/loader/entries/coreos.conf <<ENTRY
title CoreOS
linux /vmlinuz-linux
initrd /intel-ucode.img
initrd /initramfs-linux.img
options root=UUID=\$ROOT_UUID rw quiet
ENTRY

sbctl create-keys
sbctl sign-all

mkdir -p /etc/pacman.d/hooks
cat >/etc/pacman.d/hooks/secureboot.hook <<HOOK
[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = linux

[Action]
Description = Signing EFI binaries
When = PostTransaction
Exec = /usr/bin/sbctl sign-all
HOOK

EOF

umount -R /mnt
[[ "${SWAP:-}" ]] && swapoff "$SWAP"
$LUKS && cryptsetup close cryptroot || true

success "Installation finished!"
echo "Reboot and remove the installer media."