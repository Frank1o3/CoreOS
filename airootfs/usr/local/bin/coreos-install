#!/usr/bin/env bash
# =============================================================================
# CoreOS Installer
# Arch-based  |  X11 + i3  |  systemd-boot  |  Secure Boot + TPM2
# Partition layout: EFI (512M) + swap (optional) + root (ext4, remainder)
# =============================================================================

if [ -z "${BASH_VERSION:-}" ]; then
    exec /usr/bin/env bash "$0" "$@"
fi

set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[0;33m'
BLU='\033[0;34m'
BLD='\033[1m'
RST='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────────────────
info()    { echo -e "${BLU}${BLD}==> ${RST}${BLD}$*${RST}"; }
success() { echo -e "${GRN}${BLD}==> ${RST}${BLD}$*${RST}"; }
warn()    { echo -e "${YLW}${BLD}WARNING:${RST} $*"; }
die()     { echo -e "${RED}${BLD}ERROR:${RST} $*" >&2; exit 1; }

confirm() {
    local reply
    read -rp "$(echo -e "${YLW}${1} [y/N]: ${RST}")" reply
    [[ "${reply,,}" == "y" ]]
}

ask() {
    local prompt="$1" var="$2" default="${3:-}" reply
    if [[ -n "$default" ]]; then
        read -rp "$(echo -e "${BLU}${prompt} [${default}]:${RST} ")" reply
        printf -v "$var" '%s' "${reply:-$default}"
    else
        read -rp "$(echo -e "${BLU}${prompt}:${RST} ")" reply
        printf -v "$var" '%s' "$reply"
    fi
}

ask_password() {
    local prompt="$1" var="$2" pass confirm
    while true; do
        read -srp "$(echo -e "${BLU}${prompt}:${RST} ")" pass; echo
        read -srp "$(echo -e "${BLU}Confirm password:${RST} ")" confirm; echo
        [[ "$pass" == "$confirm" ]] && break
        warn "Passwords do not match, try again."
    done
    printf -v "$var" '%s' "$pass"
}

# ── Banner ────────────────────────────────────────────────────────────────────
clear
echo -e "${BLD}"
cat << 'BANNER'
   ____                ___  ____
  / ___|___  _ __ ___|  _ \/ ___|
 | |   / _ \| '__/ _ \ | | \___ \
 | |__| (_) | | |  __/ |_| |___) |
  \____\___/|_|  \___|____/|____/

  Minimal Arch-based  |  X11 + i3  |  Secure Boot + TPM2
BANNER
echo -e "${RST}"
echo ""

# ── Preflight checks ──────────────────────────────────────────────────────────
[[ $EUID -eq 0 ]]        || die "Installer must run as root."
[[ -d /sys/firmware/efi ]] || die "Not booted in UEFI mode."
ping -c1 -W3 archlinux.org &>/dev/null || die "No internet connection."

# ── Disk selection ────────────────────────────────────────────────────────────
info "Available disks:"
echo ""
lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -v loop | \
    while read -r name size model; do
        echo -e "  ${BLD}/dev/${name}${RST}  ${size}  ${model}"
    done
echo ""

ask "Target disk (e.g. sda, nvme0n1)" DISK
DISK="/dev/${DISK}"
[[ -b "$DISK" ]] || die "Disk $DISK not found."

echo ""
warn "This will DESTROY all data on ${DISK}."
confirm "Continue?" || { echo "Aborted."; exit 0; }

# ── Install options ───────────────────────────────────────────────────────────
echo ""
ask "Swap size in GB (0 to skip)" SWAP_GB "4"
ask "Hostname"                    HOSTNAME "coreos"
ask "Timezone"                    TIMEZONE "America/Santo_Domingo"
ask "Locale"                      LOCALE   "en_US.UTF-8"

# Encryption
echo ""
LUKS=false
LUKS_PASS=""
if confirm "Enable LUKS full disk encryption?"; then
    LUKS=true
    ask_password "LUKS passphrase" LUKS_PASS
fi

# User
echo ""
CREATE_USER=false
USERNAME=""
USER_PASS=""
GRANT_SUDO=false
if confirm "Create a regular user account?"; then
    CREATE_USER=true
    ask "Username" USERNAME
    ask_password "Password for ${USERNAME}" USER_PASS
    confirm "Grant sudo privileges?" && GRANT_SUDO=true
fi

echo ""
ask_password "Root password" ROOT_PASS

# ── Mirror ranking ────────────────────────────────────────────────────────────
echo ""
info "Ranking mirrors..."
if ! reflector --country 'Dominican Republic,United States' \
          --protocol https --age 12 --sort rate \
          --save /etc/pacman.d/mirrorlist 2>/dev/null; then
    warn "reflector failed, using fallback mirrors"
    cat > /etc/pacman.d/mirrorlist << 'MIRRORS'
## Fallback mirrors — reflector was unavailable or failed
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirror.math.princeton.edu/pub/archlinux/$repo/os/$arch
MIRRORS
fi
success "Mirrors configured."

# ── Partitioning ──────────────────────────────────────────────────────────────
echo ""
info "Partitioning ${DISK}..."

wipefs -af "$DISK" &>/dev/null
sgdisk --zap-all "$DISK" &>/dev/null

sgdisk -n1:0:+512M  -t1:ef00 -c1:"EFI"  "$DISK"

if [[ "$SWAP_GB" -gt 0 ]]; then
    sgdisk -n2:0:+${SWAP_GB}G -t2:8200 -c2:"swap" "$DISK"
    sgdisk -n3:0:0             -t3:8300 -c3:"root" "$DISK"
else
    sgdisk -n2:0:0 -t2:8300 -c2:"root" "$DISK"
fi

partprobe "$DISK"
sleep 2

# Partition naming — handles sda1/sda2 and nvme0n1p1/nvme0n1p2
case "$DISK" in
    *nvme*|*mmcblk*)
        PART_EFI="${DISK}p1"
        if [[ "$SWAP_GB" -gt 0 ]]; then
            PART_SWAP="${DISK}p2"
            PART_ROOT="${DISK}p3"
        else
            PART_SWAP=""
            PART_ROOT="${DISK}p2"
        fi
        ;;
    *)
        PART_EFI="${DISK}1"
        if [[ "$SWAP_GB" -gt 0 ]]; then
            PART_SWAP="${DISK}2"
            PART_ROOT="${DISK}3"
        else
            PART_SWAP=""
            PART_ROOT="${DISK}2"
        fi
        ;;
esac

success "Partitioning done."

# ── Formatting ────────────────────────────────────────────────────────────────
info "Formatting partitions..."

mkfs.fat -F32 -n EFI "$PART_EFI" &>/dev/null

if [[ "$SWAP_GB" -gt 0 ]]; then
    mkswap -L swap "$PART_SWAP" &>/dev/null
    swapon "$PART_SWAP"
fi

if $LUKS; then
    info "Setting up LUKS on root partition..."
    printf '%s' "$LUKS_PASS" | cryptsetup luksFormat \
        --type luks2 \
        --cipher aes-xts-plain64 \
        --key-size 512 \
        --hash sha512 \
        --pbkdf argon2id \
        "$PART_ROOT" --key-file -
    printf '%s' "$LUKS_PASS" | cryptsetup open "$PART_ROOT" cryptroot --key-file -
    REAL_ROOT="/dev/mapper/cryptroot"
else
    REAL_ROOT="$PART_ROOT"
fi

mkfs.ext4 -L root "$REAL_ROOT" &>/dev/null
success "Formatting done."

# ── Mounting ──────────────────────────────────────────────────────────────────
info "Mounting filesystems..."
mount "$REAL_ROOT" /mnt
mount -o umask=0077,fmask=0177,dmask=0177 --mkdir "$PART_EFI" /mnt/boot
success "Mounted."

# ── Hardware Detection ────────────────────────────────────────────────────────
info "Detecting hardware for optimized package installation..."

# Initialize hardware-specific packages array
HW_PACKAGES=()

# CPU detection
if lscpu | grep -qi intel; then
    HW_PACKAGES+=(intel-ucode)
    info "Intel CPU detected - adding intel-ucode"
elif lscpu | grep -qi amd; then
    HW_PACKAGES+=(amd-ucode)
    info "AMD CPU detected - adding amd-ucode"
fi

# GPU detection
if lspci | grep -qi nvidia; then
    HW_PACKAGES+=(nvidia-dkms nvidia-utils nvidia-settings)
    info "NVIDIA GPU detected - adding NVIDIA DKMS drivers (auto-rebuilds on kernel updates)"
fi

if lspci | grep -qi amd && lspci | grep -qi "radeon\|amdgpu"; then
    HW_PACKAGES+=(mesa xf86-video-amdgpu)
    info "AMD GPU detected - adding AMD drivers"
fi

# Intel iGPU detection (only add if no dedicated GPU or safe to coexist)
if lspci | grep -qi intel && lspci | grep -qi "integrated graphics\|hd graphics"; then
    if ! lspci | grep -qi nvidia; then
        # Safe to add Intel drivers if no NVIDIA
        HW_PACKAGES+=(mesa xf86-video-intel)
        info "Intel iGPU detected - adding Intel graphics drivers"
    else
        info "Intel iGPU + NVIDIA GPU detected - using NVIDIA drivers only"
    fi
fi

# Convert array to space-separated string for pacstrap
HW_PACKAGES_STR="${HW_PACKAGES[*]}"

# ── Pacstrap ──────────────────────────────────────────────────────────────────
mkdir -p /mnt/var/cache/pacman/pkg
cp /var/cache/pacman/pkg/*.pkg.tar.zst \
    /mnt/var/cache/pacman/pkg/ 2>/dev/null || true

info "Installing base system (this will take a while)..."
# Note: AUR packages (networkmanager-applet) will be installed after paru is bootstrapped
pacstrap -K /mnt --needed \
    base base-devel linux linux-firmware \
    systemd-ukify sbctl sbsigntools tpm2-tools tpm2-tss efibootmgr \
    networkmanager iwd \
    bluez bluez-utils \
    pipewire pipewire-pulse pipewire-alsa wireplumber \
    xorg-server xorg-xinit xorg-xrandr \
    i3-wm i3status i3lock dmenu i3blocks alacritty \
    git curl wget rsync \
    vim nano less \
    sudo zsh grml-zsh-config \
    man-db man-pages \
    ttf-dejavu ttf-liberation noto-fonts \
    xdg-utils xdg-user-dirs xdg-desktop-portal xdg-desktop-portal-gtk \
    brightnessctl \
    unzip zip p7zip \
    htop fastfetch \
    picom \
    $HW_PACKAGES_STR

success "Base system installed."

# ── fstab ─────────────────────────────────────────────────────────────────────
info "Generating fstab..."
genfstab -U /mnt >> /mnt/etc/fstab
# Lock down EFI partition permissions via mount options
sed -i 's|\(vfat.*defaults\)|\1,umask=0077,fmask=0177,dmask=0077|' \
    /mnt/etc/fstab
success "fstab done."

# ── Chroot: System Basics ────────────────────────────────────────────────────
info "Configuring system basics (timezone, locale, hostname)..."

arch-chroot /mnt /usr/bin/env \
    TIMEZONE="${TIMEZONE}" \
    LOCALE="${LOCALE}" \
    HOSTNAME="${HOSTNAME}" \
    LUKS="${LUKS}" \
    /bin/bash << 'CHROOT_BASICS'
set -euo pipefail

# ── Timezone + locale ─────────────────────────────────────────────────────────
ln -sf /usr/share/zoneinfo/${TIMEZONE} /etc/localtime
hwclock --systohc
sed -i "s/^# *${LOCALE}/${LOCALE}/" /etc/locale.gen
locale-gen
echo "LANG=${LOCALE}" > /etc/locale.conf

# ── Hostname ──────────────────────────────────────────────────────────────────
echo "${HOSTNAME}" > /etc/hostname
cat > /etc/hosts << HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   ${HOSTNAME}.localdomain ${HOSTNAME}
HOSTS

# ── mkinitcpio ────────────────────────────────────────────────────────────────
if ${LUKS}; then
    sed -i 's/^HOOKS=.*/HOOKS=(base udev autodetect microcode modconf kms keyboard keymap consolefont block encrypt filesystems fsck)/' \
        /etc/mkinitcpio.conf
else
    sed -i 's/^HOOKS=.*/HOOKS=(base udev autodetect microcode modconf kms keyboard keymap consolefont block filesystems fsck)/' \
        /etc/mkinitcpio.conf
fi
mkinitcpio -P
CHROOT_BASICS

success "System basics configured."

# ── Chroot: Users ─────────────────────────────────────────────────────────────
info "Configuring users and authentication..."

arch-chroot /mnt /usr/bin/env \
    CREATE_USER="${CREATE_USER}" \
    USERNAME="${USERNAME}" \
    USER_PASS="${USER_PASS}" \
    GRANT_SUDO="${GRANT_SUDO}" \
    ROOT_PASS="${ROOT_PASS}" \
    /bin/bash << 'CHROOT_USERS'
set -euo pipefail

# ── Users ─────────────────────────────────────────────────────────────────
echo "root:${ROOT_PASS}" | chpasswd

if ${CREATE_USER}; then
    # Create user (skel files auto-copied by -m flag)
    useradd -m -G wheel,audio,video,input -s /bin/zsh ${USERNAME}
    echo "${USERNAME}:${USER_PASS}" | chpasswd
    if ${GRANT_SUDO}; then
        sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' \
            /etc/sudoers
    fi
fi
CHROOT_USERS

success "Users configured."

# ── Chroot: Bootloader ────────────────────────────────────────────────────────
info "Configuring bootloader and Secure Boot..."

arch-chroot /mnt /usr/bin/env \
    LUKS="${LUKS}" \
    PART_ROOT="${PART_ROOT}" \
    REAL_ROOT="${REAL_ROOT}" \
    /bin/bash << 'CHROOT_BOOT'
set -euo pipefail

# ── systemd-boot ──────────────────────────────────────────────────────────────
bootctl install

cat > /boot/loader/loader.conf << LOADER
default coreos.conf
timeout 5
console-mode auto
editor no
LOADER

# Build kernel cmdline — LUKS needs cryptdevice, not just root UUID
if ${LUKS}; then
    LUKS_UUID=$(blkid -s UUID -o value ${PART_ROOT})
    CMDLINE="cryptdevice=UUID=${LUKS_UUID}:cryptroot root=/dev/mapper/cryptroot rw quiet"
else
    ROOT_UUID=$(blkid -s UUID -o value ${REAL_ROOT})
    CMDLINE="root=UUID=${ROOT_UUID} rw quiet"
fi

cat > /boot/loader/entries/coreos.conf << ENTRY
title   CoreOS
linux   /vmlinuz-linux
initrd  /intel-ucode.img
initrd  /initramfs-linux.img
options ${CMDLINE}
ENTRY

# ── Secure Boot ───────────────────────────────────────────────────────────────
# ── Secure Boot ───────────────────────────────────────────────────────────────
sbctl create-keys
sbctl sign -s /boot/EFI/systemd/systemd-bootx64.efi

# Only sign the kernel if it's an EFISTUB binary (Arch's linux package is)
if file /boot/vmlinuz-linux | grep -q "PE32+ executable"; then
    sbctl sign -s /boot/vmlinuz-linux
fi

# Skip ucode/initrd - they are not EFI binaries
# They will be loaded by the signed kernel/bootloader

# Lock down /boot permissions
find /boot -type d -exec chmod 700 {} \;
find /boot -type f -exec chmod 600 {} \;
CHROOT_BOOT

success "Bootloader configured."

# ── Chroot: Services ──────────────────────────────────────────────────────────
info "Configuring services..."

arch-chroot /mnt /bin/bash << 'CHROOT_SERVICES'
set -euo pipefail

# ── Services ──────────────────────────────────────────────────────────────
systemctl enable NetworkManager
systemctl enable iwd
systemctl enable bluetooth

# ── CoreOS repo ───────────────────────────────────────────────────────────────
# SigLevel Optional for bootstrap — firstupdate upgrades it after keyring installs
cat >> /etc/pacman.conf << PACREPO

[coreos]
SigLevel = Optional TrustAll
Server = https://frank1o3.github.io/CoreOS-repo/x86_64
PACREPO

# ── First boot service — Secure Boot enrollment + TPM2 ───────────────────────
cat > /usr/local/bin/coreos-firstboot << 'FIRSTBOOT'
#!/usr/bin/env bash
set -euo pipefail

LOG=/var/log/coreos-firstboot.log
exec > >(tee -a "$LOG") 2>&1

echo "[coreos-firstboot] Starting..."

# Secure Boot key enrollment
if sbctl status | grep -q "Setup Mode.*Enabled"; then
    sbctl enroll-keys --microsoft
    echo "[coreos-firstboot] Secure Boot keys enrolled."
else
    echo "[coreos-firstboot] WARNING: Not in Setup Mode."
    echo "[coreos-firstboot] Run manually: sbctl enroll-keys --microsoft"
fi

# TPM2 — seal LUKS key to PCR 7 (Secure Boot state)
if [[ -b /dev/tpmrm0 ]]; then
    LUKS_PART=$(blkid -t TYPE=crypto_LUKS -o device | head -n1)
    if [[ -n "$LUKS_PART" ]]; then
        systemd-cryptenroll \
            --tpm2-device=auto \
            --tpm2-pcrs=7 \
            "$LUKS_PART" \
            && echo "[coreos-firstboot] TPM2 enrollment done." \
            || echo "[coreos-firstboot] WARNING: TPM2 failed. Passphrase still works."
    else
        echo "[coreos-firstboot] No LUKS partition found, skipping TPM2."
    fi
else
    echo "[coreos-firstboot] No TPM2 device, skipping."
fi

echo "[coreos-firstboot] Done."
FIRSTBOOT
chmod 755 /usr/local/bin/coreos-firstboot

cat > /etc/systemd/system/coreos-firstboot.service << FBSERVICE
[Unit]
Description=CoreOS first boot — Secure Boot + TPM2
ConditionPathExists=!/etc/coreos-firstboot-done
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/coreos-firstboot
ExecStartPost=/usr/bin/touch /etc/coreos-firstboot-done
RemainAfterExit=yes
StandardOutput=journal+console

[Install]
WantedBy=multi-user.target
FBSERVICE

systemctl enable coreos-firstboot.service

# ── First update service — repo bootstrap + full system update ───────────────
cat > /usr/local/bin/coreos-firstupdate << 'FIRSTUPDATE'
#!/usr/bin/env bash
set -euo pipefail

LOG=/var/log/coreos-firstupdate.log
exec > >(tee -a "$LOG") 2>&1

COREOS_KEY="5128C09E64959EFA"
KEYSERVER_URL="https://frank1o3.github.io/CoreOS-repo/coreos-repo.gpg"

echo "[coreos-firstupdate] Syncing package databases..."
pacman -Sy --noconfirm

echo "[coreos-firstupdate] Bootstrapping CoreOS keyring..."
# Wait for pacman-init to finish if still running
for i in $(seq 1 30); do
    if systemctl --quiet is-active pacman-init.service 2>/dev/null; then
        sleep 2
    else
        break
    fi
done

# Import key with error handling
if ! curl -sf "$KEYSERVER_URL" | pacman-key --add -; then
    echo "[coreos-firstupdate] ERROR: Failed to download/import CoreOS GPG key."
    echo "[coreos-firstupdate] Check your internet connection and key server URL."
    echo "[coreos-firstupdate] Manual recovery: curl -s $KEYSERVER_URL | pacman-key --add -"
    exit 1
fi

if ! pacman-key --lsign-key "$COREOS_KEY" 2>/dev/null; then
    echo "[coreos-firstupdate] ERROR: Failed to locally sign CoreOS GPG key ($COREOS_KEY)."
    echo "[coreos-firstupdate] The key may have expired or be invalid."
    echo "[coreos-firstupdate] Manual recovery: pacman-key --lsign-key $COREOS_KEY"
    exit 1
fi

# Install keyring — key is now permanently managed by pacman
if ! pacman -S --noconfirm coreos/coreos-keyring; then
    echo "[coreos-firstupdate] ERROR: Failed to install coreos-keyring package."
    exit 1
fi
pacman-key --populate coreos 2>/dev/null || true

# Upgrade SigLevel now that keyring is installed
sed -i '/\[coreos\]/{n;s/SigLevel = Optional TrustAll/SigLevel = Required DatabaseOptional/}' \
    /etc/pacman.conf

echo "[coreos-firstupdate] Running full system update..."
pacman -Su --noconfirm

echo "[coreos-firstupdate] Done."
FIRSTUPDATE
chmod 755 /usr/local/bin/coreos-firstupdate

cat > /etc/systemd/system/coreos-firstupdate.service << FUSERVICE
[Unit]
Description=CoreOS first boot — repo bootstrap + system update
ConditionPathExists=!/etc/coreos-firstupdate-done
After=network-online.target coreos-firstboot.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/coreos-firstupdate
ExecStartPost=/usr/bin/touch /etc/coreos-firstupdate-done
RemainAfterExit=yes
StandardOutput=journal+console

[Install]
WantedBy=multi-user.target
FUSERVICE

systemctl enable coreos-firstupdate.service
CHROOT_SERVICES

success "Services configured."

# ── Chroot: Environment ───────────────────────────────────────────────────────
info "Configuring desktop environment and sessions..."

arch-chroot /mnt /usr/bin/env \
    CREATE_USER="${CREATE_USER}" \
    USERNAME="${USERNAME}" \
    /bin/bash << 'CHROOT_ENV'
set -euo pipefail

# Ensure skel configs are executable
chmod +x /etc/skel/.xinitrc 2>/dev/null || true

if ${CREATE_USER}; then
    # Auto-login the created user on tty1
    mkdir -p /etc/systemd/system/getty@tty1.service.d/
    cat > /etc/systemd/system/getty@tty1.service.d/autologin.conf << AUTOLOGIN
[Service]
ExecStart=
ExecStart=-/sbin/agetty -o '-p -f -- \\\\u' --noclear --autologin ${USERNAME} - \\\$TERM
AUTOLOGIN

    # Copy skel configs to user home (useradd -m already copied basics, but we ensure .config/)
    cp -a /etc/skel/.xinitrc /etc/skel/.zlogin /home/${USERNAME}/ 2>/dev/null || true
    [[ -d /etc/skel/.config ]] && cp -a /etc/skel/.config /home/${USERNAME}/ 2>/dev/null || true
    chown -R ${USERNAME}:${USERNAME} /home/${USERNAME}/.xinitrc /home/${USERNAME}/.zlogin /home/${USERNAME}/.config 2>/dev/null || true
else
    # No user created — set up root with skel configs so system is still usable
    echo "WARNING: No regular user created. Root will use skel configs for auto-start X."
    cp -a /etc/skel/.xinitrc /etc/skel/.zlogin /root/ 2>/dev/null || true
    [[ -d /etc/skel/.config ]] && cp -a /etc/skel/.config /root/ 2>/dev/null || true
fi
CHROOT_ENV

success "Desktop environment configured."

# ── AUR Packages ──────────────────────────────────────────────────────────────
if [[ "${CREATE_USER}" == "true" ]]; then
    info "Installing AUR packages..."

    # ── Paru ──────────────────────────────────────────────────────────────────────
    echo "[paru] Installing paru-bin..."

    useradd -m -r -s /bin/bash builduser 2>/dev/null || true
    echo "builduser ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/builduser
    mkdir -p /opt/paru-build
    chown builduser:builduser /opt/paru-build

    sudo -u builduser git clone \
        https://aur.archlinux.org/paru-bin.git \
        /opt/paru-build/paru-bin

    cd /opt/paru-build/paru-bin
    sudo -u builduser makepkg -si --noconfirm --noprogressbar

    userdel -r builduser 2>/dev/null || true
    rm -f /etc/sudoers.d/builduser
    rm -rf /opt/paru-build

    # AUR packages
    arch-chroot /mnt /usr/bin/env \
        USERNAME="${USERNAME}" \
        /bin/bash << 'CHROOT_AUR'
    set -euo pipefail

    # Paru config for regular user
    mkdir -p /home/${USERNAME}/.config/paru
    cat > /home/${USERNAME}/.config/paru/paru.conf << 'PARUCONF'
[options]
BottomUp
SudoLoop
Devel
CleanAfter
NewsOnUpgrade
PARUCONF
    chown -R ${USERNAME}:${USERNAME} /home/${USERNAME}/.config/paru

    # Install AUR packages
    echo "[aur] Installing AUR packages via paru..."
    sudo -u ${USERNAME} paru -S --noconfirm \
        networkmanager-applet
    echo "[aur] AUR packages installed."
CHROOT_AUR

    success "AUR packages installed."
fi

# ── Cleanup ───────────────────────────────────────────────────────────────────
umount -R /mnt
[[ -n "${PART_SWAP:-}" ]] && swapoff "$PART_SWAP" 2>/dev/null || true
$LUKS && cryptsetup close cryptroot 2>/dev/null || true

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${GRN}${BLD}════════════════════════════════════════${RST}"
echo -e "${GRN}${BLD}  CoreOS installation complete!${RST}"
echo -e "${GRN}${BLD}════════════════════════════════════════${RST}"
echo ""
echo -e "  Hostname   : ${BLD}${HOSTNAME}${RST}"
echo -e "  Disk       : ${BLD}${DISK}${RST}"
echo -e "  Encryption : ${BLD}$($LUKS && echo 'LUKS2' || echo 'none')${RST}"
echo -e "  Secure Boot: ${BLD}Signed. Set UEFI to Setup Mode before reboot.${RST}"
echo -e "  TPM2       : ${BLD}Auto-enrolls on first boot (LUKS only).${RST}"
echo -e "  Repo       : ${BLD}CoreOS repo added. Keyring installs on first boot.${RST}"
echo ""
echo -e "  ${YLW}Next steps:${RST}"
echo -e "  1. Enter UEFI firmware → enable ${BLD}Setup Mode${RST}"
echo -e "  2. Remove installer media and reboot"
echo -e "  3. First boot will enroll Secure Boot keys + update system"
echo ""
